---
import ExperienceItem from "./ExperienceItem.astro"

const EXPERIENCE = [
    {
      date: 'Actualmente',
      title: 'Desarrollador Full Stack',
      description: `Desarrollo soluciones de software a medida y participo en todo el ciclo del producto, 
      desde la construcción de interfaces hasta la lógica de negocio y la integración con backend. 
      Mi enfoque está en entregar productos sólidos, mantenibles y alineados con los objetivos del cliente.`,
      link: 'https://www.devontic.com/',
    },
]
---
<ol class="relative ml-3 border-s border-white/10" data-reveal style="--reveal-delay: 120ms;">                  
    {
        EXPERIENCE.map((item) => (
            <ExperienceItem
              {...item}
            />
        ))
    }
</ol>

