---
import ExperienceItem from "./ExperienceItem.astro"

const EXPERIENCE = [
    {
      date: 'Actualmente',
      title: 'Desarrollador Full Stack',
      description: `Desarrollando soluciones de software a medida. 
      Colaboro en todas las etapas del proyecto, desde el frontend 
      hasta el backend, para crear productos que satisfacen las necesidades 
      específicas del cliente.`,
      link: 'https://www.devontic.com/',
    },
]
---
<ol class="relative border-s border-gray-200 dark:border-gray-700 ml-3">                  
    {
        EXPERIENCE.map((item) => (
            <ExperienceItem
              {...item}
            />
        ))
    }
</ol>

