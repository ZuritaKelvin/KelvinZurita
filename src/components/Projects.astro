---
import HTMLIcon from '../components/icons/HTMLIcon.astro';	
import JSIcon from '../components/icons/JSIcon.astro';
import Github from './icons/Github.astro';
import LinkButton from './LinkButton.astro';
import ShadCnICON from './icons/ShadCnICON.astro';
import NextJSIcon from './icons/NextJSIcon.astro';
import SupabaseIcon from './icons/SupabaseIcon.astro';
import PreviewIcon from './icons/PreviewIcon.astro';

const TAGS = {
    HTML: {
        name: 'HTML',
        class: 'bg-black text-white',
        icon: HTMLIcon,
    },
    JS: {
        name: 'JavaScript',
        class: 'bg-black text-white',
        icon: JSIcon,
    },
    SHADCN: {
        name: 'ShadCn/UI',
        class: 'bg-black text-white',
        icon: ShadCnICON,
    },
    NEXTJS: {
        name: 'Next JS',
        class: 'bg-black text-white',
        icon: NextJSIcon,
    },
    SUPABASE: {
        name: 'Supabase',
        class: 'bg-black text-white',
        icon: SupabaseIcon,
    }
};

const PROJECTS = [
    {
        title: 'AuraBill',
        description: 'Aplicación web para la administración y gestión de facturación con implementación de IA para la digitalización y generación automatizada de facturas.',
        link: null,
        github: null,
        image: null,
        tags: [TAGS.SHADCN, TAGS.NEXTJS, TAGS.SUPABASE],
        inProgress: true,
    },
    {
        title: 'Clon de MonkeyType',
        description: 'Clon de la conocida plataforma Monkeytype para mejorar la rapidez y fluidez al escribir. Implementado con HTML, CSS y JavaScript vanilla.',
        link: 'https://zuritakelvin.github.io/TypeFaster/',
        github: 'https://github.com/ZuritaKelvin/TypeFaster',
        image: '/projects/monkeyType.png',
        tags: [TAGS.HTML, TAGS.JS],
        inProgress: false,
    },
];
---

<div class="grid gap-8">
    {PROJECTS.map((project, index) => (
        <article 
            class="group relative rounded-2xl border border-white/10 bg-white/5 p-6 transition-all hover:border-white/20 hover:bg-white/[0.08]"
            data-reveal 
            style={`--reveal-delay: ${index * 120}ms;`}
        >
            <div class="flex flex-col gap-4">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <h3 class="text-xl font-semibold text-white group-hover:text-blue-200 transition-colors">
                            {project.title}
                            {project.inProgress && (
                                <span class="ml-3 inline-flex items-center rounded-full bg-yellow-500/20 px-2 py-0.5 text-xs font-medium text-yellow-400">
                                    En progreso
                                </span>
                            )}
                        </h3>
                        <p class="mt-2 text-sm leading-relaxed text-zinc-400">
                            {project.description}
                        </p>
                    </div>
                </div>

                {project.tags.length > 0 && (
                    <ul class="flex flex-wrap gap-2">
                        {project.tags.map((tag) => (
                            <li>
                                <span class={`inline-flex items-center gap-1.5 rounded-full text-xs py-1.5 px-3 ${tag.class}`}>
                                    <tag.icon />
                                    {tag.name}
                                </span>
                            </li>
                        ))}
                    </ul>
                )}

                {project.inProgress ? (
                    <div class="flex items-center gap-2 text-sm text-zinc-500">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <polyline points="12 6 12 12 16 14"/>
                        </svg>
                        Próximamente disponible
                    </div>
                ) : (
                    <>
                        {project.image && (
                            <div class="overflow-hidden rounded-xl border border-white/10">
                                <img 
                                    src={project.image} 
                                    alt={`Captura de pantalla del proyecto ${project.title}`}
                                    class="h-auto w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                                    loading="lazy"
                                />
                            </div>
                        )}
                        <footer class="flex gap-3">
                            {project.link && (
                                <LinkButton href={project.link} target="_blank">
                                    <PreviewIcon />
                                    Ver demo
                                </LinkButton>
                            )}
                            {project.github && (
                                <LinkButton href={project.github} target="_blank">
                                    <Github />
                                    Código fuente
                                </LinkButton>
                            )}
                        </footer>
                    </>
                )}
            </div>
        </article>
    ))}
</div>
