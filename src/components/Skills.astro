---
import TypeScriptIcon from '../components/icons/TypeScriptIcon.astro';
import JSIcon from '../components/icons/JSIcon.astro';
import HTMLIcon from '../components/icons/HTMLIcon.astro';
import CSSIcon from '../components/icons/CSSIcon.astro';
import ReactIcon from '../components/icons/ReactIcon.astro';
import NextJSIcon from '../components/icons/NextJSIcon.astro';
import AstroIcon from '../components/icons/AstroIcon.astro';
import NodeIcon from '../components/icons/NodeIcon.astro';
import TailwindIcon from '../components/icons/TailwindIcon.astro';
import GitIcon from '../components/icons/GitIcon.astro';
import PostgresIcon from '../components/icons/PostgresIcon.astro';
import SupabaseIcon from '../components/icons/SupabaseIcon.astro';
import ShadCnICON from '../components/icons/ShadCnICON.astro';

const SKILLS = {
    languages: {
        title: 'Lenguajes',
        items: [
            { name: 'TypeScript', icon: TypeScriptIcon },
            { name: 'JavaScript', icon: JSIcon },
            { name: 'HTML', icon: HTMLIcon },
            { name: 'CSS', icon: CSSIcon },
        ]
    },
    frameworks: {
        title: 'Frameworks & Librerías',
        items: [
            { name: 'React', icon: ReactIcon },
            { name: 'Next.js', icon: NextJSIcon },
            { name: 'Astro', icon: AstroIcon },
            { name: 'Node.js', icon: NodeIcon },
            { name: 'Tailwind CSS', icon: TailwindIcon },
            { name: 'Shadcn/UI', icon: ShadCnICON },
        ]
    },
    tools: {
        title: 'Herramientas & Otros',
        items: [
            { name: 'Git', icon: GitIcon },
            { name: 'PostgreSQL', icon: PostgresIcon },
            { name: 'Supabase', icon: SupabaseIcon },
        ]
    }
};
---

<div class="space-y-8">
    {Object.entries(SKILLS).map(([_, category], categoryIndex) => (
        <div data-reveal style={`--reveal-delay: ${categoryIndex * 80}ms;`}>
            <h3 class="mb-4 text-sm font-medium uppercase tracking-[0.15em] text-slate-400">
                {category.title}
            </h3>
            <ul class="flex flex-wrap gap-3">
                {category.items.map((skill) => (
                    <li 
                        class="group relative flex items-center gap-2.5 rounded-full border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-zinc-300 transition-all hover:border-white/20 hover:bg-white/10 hover:text-white"
                        title={skill.name}
                    >
                        <span class="flex h-5 w-5 shrink-0 items-center justify-center text-zinc-100/90">
                            <skill.icon />
                        </span>
                        <span>{skill.name}</span>
                    </li>
                ))}
            </ul>
        </div>
    ))}
</div>
