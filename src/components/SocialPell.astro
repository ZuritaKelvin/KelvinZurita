<a class="rounded-full text-white border border-white/10 bg-white/5 hover:scale-110 hover:bg-white/10 transition flex justify-center items-center gap-x-2 py-1 px-1.5"
{...Astro.props}
target="_blank"
rel="noopener noreferrer"
aria-label={Astro.props.href?.includes('linkedin') ? 'Visitar perfil de LinkedIn' : 
           Astro.props.href?.includes('github') ? 'Visitar perfil de GitHub' : 
           Astro.props.href?.includes('mailto') ? 'Enviar correo electrónico' : 
           'Visitar enlace externo'}
>
    <slot />
</a>
