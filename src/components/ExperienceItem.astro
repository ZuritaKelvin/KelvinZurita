---
const { date, title, description, link } = Astro.props
---
<li class="mb-10 ms-4">
    <div class="absolute mt-2 h-3 w-3 rounded-full border border-[#0b0d11] bg-zinc-300 -start-1.5"></div>
    <time class="mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">{date}</time>
    {link ? (
        <h3 class="text-lg font-semibold text-zinc-100">
            <a href={link} target="_blank" rel="noopener noreferrer" class="hover:text-white hover:underline">{title}</a>
        </h3>
    ) : (
        <h3 class="text-lg font-semibold text-zinc-100">{title}</h3>
    )}
    <p class="mt-3 max-w-3xl text-base leading-7 text-zinc-300 text-pretty">{description}</p>
</li>
