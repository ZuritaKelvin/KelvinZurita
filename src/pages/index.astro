---
import Layout from '../layouts/Layout.astro';
import LinkedIn from '../components/icons/LinkedIn.astro';
import Github from '../components/icons/Github.astro';
import SocialPell from '../components/SocialPell.astro';
import CloseEmail from '../components/icons/CloseEmail.astro';
import Experience from '../components/Experience.astro';
import WorkIcon from '../components/icons/WorkIcon.astro';
import CodeIcon from '../components/icons/CodeIcon.astro';
import Projects from '../components/Projects.astro';
import AboutMeIcon from '../components/icons/AboutMeIcon.astro';
import AboutMe from '../components/AboutMe.astro';
import SkillsIcon from '../components/icons/SkillsIcon.astro';
import Skills from '../components/Skills.astro';
---

<Layout title="Kelvin Zurita - Programador y Desarrollador Full-Stack">
	<main>
		<section class="section-shell overflow-hidden pt-8 md:pt-12" data-reveal>
			<div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_260px] lg:items-end">
				<div data-reveal style="--reveal-delay: 80ms;">
					<div class="mb-6 inline-flex rounded-full border border-white/8 px-3 py-1 text-xs font-medium uppercase tracking-[0.22em] text-slate-300">
						Full-Stack Developer
					</div>
					<h1 class="max-w-3xl text-4xl font-bold leading-tight tracking-tight text-white md:text-6xl">
						Kelvin Zurita
					</h1>
					<p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300 md:text-xl">
						2 años de experiencia desarrollando productos full stack con foco en rendimiento,
						escalabilidad y experiencia de usuario. Me gusta construir soluciones claras,
						bien pensadas y preparadas para crecer con el negocio.
					</p>
					<p class="mt-4 max-w-2xl text-base leading-7 text-slate-400 md:text-lg">
						Trabajo con una mentalidad de mejora continua: entender el problema, diseñar una
						solución sostenible y ejecutarla con atención al detalle.
					</p>
					<nav class="mt-8 flex flex-wrap gap-3">
						<SocialPell href="https://www.linkedin.com/in/kelvin-zurita-0768541b0?utm_source=share&utm_campaign=share_via&utm_content=profile&utm_medium=android_app">
							LinkedIn
							<LinkedIn />
						</SocialPell>
						<SocialPell href="https://github.com/ZuritaKelvin">
							Github
							<Github />
						</SocialPell >
						<SocialPell href="mailto:kelvinzurita2015@gmail.com">
							Gmail
							<CloseEmail />
						</SocialPell >
					</nav>
				</div>
				<div class="grid gap-6 border-l border-white/8 pl-5 sm:grid-cols-3 sm:border-l-0 sm:pl-0 lg:grid-cols-1 lg:border-l lg:pl-5" data-reveal style="--reveal-delay: 180ms;">
					<div class="border-b border-white/8 pb-4 lg:border-b lg:border-white/8" data-reveal style="--reveal-delay: 220ms;">
						<p class="text-sm uppercase tracking-[0.2em] text-slate-400">Experiencia</p>
						<p class="mt-3 text-3xl font-bold text-white">2+</p>
						<p class="mt-2 text-sm leading-6 text-slate-300">Años trabajando en frontend, backend e integración de producto.</p>
					</div>
					<div class="border-b border-white/8 pb-4 lg:border-b lg:border-white/8" data-reveal style="--reveal-delay: 280ms;">
						<p class="text-sm uppercase tracking-[0.2em] text-slate-400">Especialidad</p>
						<p class="mt-3 text-xl font-semibold text-white">Aplicaciones full stack</p>
						<p class="mt-2 text-sm leading-6 text-slate-300">Interfaces modernas, lógica de negocio sólida y APIs pensadas para escalar.</p>
					</div>
					<div data-reveal style="--reveal-delay: 340ms;">
						<p class="text-sm uppercase tracking-[0.2em] text-slate-400">Enfoque</p>
						<p class="mt-3 text-xl font-semibold text-white">Calidad y criterio</p>
						<p class="mt-2 text-sm leading-6 text-slate-300">Código mantenible, decisiones claras y atención real a la experiencia final.</p>
					</div>
				</div>
			</div>
		</section>
		<section class="section-shell" id="experience" data-reveal>
			<h2 class="section-heading text-white" data-reveal>
				<WorkIcon />
				Experiencia Laboral</h2>
			<Experience />
		</section>
		<section class="section-shell" id="skills" data-reveal>
			<h2 class="section-heading text-white" data-reveal>
				<SkillsIcon />
				Tecnologías</h2>
			<Skills />
		</section>
		<section class="section-shell" id="projects" data-reveal>
			<h2 class="section-heading text-white" data-reveal>
				<CodeIcon />
				Proyectos</h2>
			<Projects />
		</section>
		<section class="section-shell mb-0" id="about" data-reveal>
			<h2 class="section-heading text-white" data-reveal>
				<AboutMeIcon />
				Sobre mi</h2>
			<AboutMe />
		</section>
		<section class="section-shell mb-0" id="contact" data-reveal>
			<div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
				<div class="max-w-2xl" data-reveal>
					<p class="text-sm font-medium uppercase tracking-[0.22em] text-slate-400">Contacto</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight text-white md:text-4xl">
						¿Hablamos sobre tu próximo proyecto?
					</h2>
					<p class="mt-4 text-base leading-7 text-slate-300 md:text-lg">
						Si querés contarme una idea, explorar una colaboración o tenés una oportunidad
						profesional, podés escribirme directamente y te respondo por correo.
					</p>
				</div>
				<div data-reveal style="--reveal-delay: 120ms;">
					<a
						href="mailto:kelvinzurita2015@gmail.com"
						class="inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm font-medium text-white hover:border-white/20 hover:bg-white/10"
					>
						<CloseEmail />
						kelvinzurita2015@gmail.com
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
